{
  "extends": [
    "config:base",
    ":dependencyDashboard",
    ":automergePatch"
  ],

  "baseBranches": ["master"],

  "timezone": "America/Guadeloupe",

  "rangeStrategy": "bump",

  "packageRules": [
    {
      "matchManagers": ["npm"],
      "groupName": "npm dependencies"
    },

   {

      "matchUpdateTypes": ["patch"],

      "automerge": true

    },

    {

      "matchPackageNames": ["node"],

      "automerge": false

    },

    {

      "matchPackagePatterns": ["webpack", "budo", "aframe"],

      "automerge": false

    }
  ]
}
