{
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":automergePatch"
  ],

  "baseBranchPatterns": [
    "master"
  ],

  "timezone": "America/Guadeloupe",

  "rangeStrategy": "bump",

  "packageRules": [
    {
      "matchManagers": ["npm"],
      "groupName": "npm dependencies"
    },

   {

      "matchUpdateTypes": ["patch"],

      "automerge": true

    },

    {

      "matchPackageNames": ["node"],

      "automerge": false

    },

    {

      "automerge": false,
      "matchPackageNames": [
        "/webpack/",
        "/budo/",
        "/aframe/"
      ]
    }
  ]
}
